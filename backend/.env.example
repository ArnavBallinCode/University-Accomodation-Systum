# DB_HOST=your-mysql-host
# DB_PORT=3306
# DB_USER=your-mysql-user
# DB_PASSWORD=your-mysql-password-or-empty
# DB_NAME=your-database-name
# DB_TLS_MODE=preferred
# DB_CA_CERT_PATH=ca.pem
# PORT=8000

# -----------------------------------------------------------------------------
# Railway variable reference (comment-only)
# -----------------------------------------------------------------------------
# MYSQLDATABASE=
# MYSQLHOST=
# MYSQLPASSWORD=
# MYSQLPORT=
# MYSQLUSER=
# MYSQL_DATABASE=
# MYSQL_PUBLIC_URL=mysql://<user>:<password>@<host>:<port>/<db>
# MYSQL_ROOT_PASSWORD=
# MYSQL_URL=mysql://<user>:<password>@<host>:<port>/<db>
#
# Mapping to this backend app:
# DB_HOST=<MYSQLHOST>
# DB_PORT=<MYSQLPORT>
# DB_USER=<MYSQLUSER>
# DB_PASSWORD=<MYSQLPASSWORD>
# DB_NAME=<MYSQLDATABASE or MYSQL_DATABASE>
# DB_TLS_MODE=preferred
# DB_CA_CERT_PATH=ca.pem

# -----------------------------------------------------------------------------
# Aiven template (comment-only)
# -----------------------------------------------------------------------------
# DB_HOST=<your-aiven-host>
# DB_PORT=<your-aiven-port>
# DB_USER=<your-aiven-username>
# DB_PASSWORD=<your-aiven-password>
# DB_NAME=<your-aiven-database>
# DB_TLS_MODE=preferred
# DB_CA_CERT_PATH=ca.pem
#
# Temporary fallback if CA validation blocks startup:
# DB_TLS_MODE=skip-verify

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=uni_accom_python
DB_TLS_MODE=false
DB_CA_CERT_PATH=
PORT=8000
